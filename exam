// ══════════════════════════════════════════════════════════════
// ENGINE
// ══════════════════════════════════════════════════════════════
let pyodide = null, pyReady = false;
function setEngineStatus(text, state) {
  document.getElementById('stext').textContent = text;
  document.getElementById('sdot').className = 'status-dot ' + state;
}
async function initPy() {
  try {
    pyodide = await loadPyodide();
    await pyodide.loadPackage(['numpy','scipy']);
    pyReady = true;
    setEngineStatus('scipy / HiGHS ready','ready');
    document.getElementById('solve-btn').disabled = false;
    setSolveMsg('Ready to optimize','ok');
  } catch(e) {
    setEngineStatus('Engine error','err');
    setSolveMsg('Failed: '+e.message,'err');
  }
}
function setSolveMsg(msg,cls=''){const el=document.getElementById('solve-msg');el.textContent=msg;el.className='solve-msg-el '+cls}

// ══════════════════════════════════════════════════════════════
// Q1 — CONSTRAINT TOGGLE
// ══════════════════════════════════════════════════════════════
const cState={minOpen:true,minUtil:true,maxOpen:false,singleSrc:false};
function toggleConstraint(key){
  cState[key]=!cState[key];
  const ck=document.getElementById('ck_'+key),cb=document.getElementById('cb_'+key),ci=document.getElementById('ci_'+key);
  ck.className='c-check'+(cState[key]?' checked':'');
  if(cb) cb.className='c-body'+(cState[key]?' open':'');
  ci.className='c-item'+(cState[key]?' active':'');
}
function parseList(s){return s.split(',').map(x=>parseFloat(x.trim())).filter(v=>!isNaN(v))}
function parseMatrix(s,nW,nC){const rows=s.trim().split('\n').map(r=>r.split(',').map(v=>parseFloat(v.trim())));if(rows.length!==nW||rows.some(r=>r.length!==nC||r.some(isNaN)))return null;return rows}

// ══════════════════════════════════════════════════════════════
// Q1 — SOLVER
// ══════════════════════════════════════════════════════════════
async function runSolver(){
  if(!pyReady)return;
  const nW=parseInt(document.getElementById('nW').value);
  const nC=parseInt(document.getElementById('nC').value);
  const fixedCosts=parseList(document.getElementById('fixedCosts').value);
  const capacities=parseList(document.getElementById('capacities').value);
  const demands=parseList(document.getElementById('demands').value);
  const matrix=parseMatrix(document.getElementById('costMatrix').value,nW,nC);
  if(fixedCosts.length!==nW){setSolveMsg(`Fixed costs: need ${nW}, got ${fixedCosts.length}`,'err');return}
  if(capacities.length!==nW){setSolveMsg(`Capacities: need ${nW}, got ${capacities.length}`,'err');return}
  if(demands.length!==nC){setSolveMsg(`Demands: need ${nC}, got ${demands.length}`,'err');return}
  if(!matrix){setSolveMsg(`Matrix must be ${nW}×${nC}`,'err');return}
  const minOpen=cState.minOpen?parseInt(document.getElementById('minOpenVal').value):0;
  const maxOpen=cState.maxOpen?parseInt(document.getElementById('maxOpenVal').value):nW;
  const minUtilPct=cState.minUtil?parseFloat(document.getElementById('minUtilVal').value):0;
  const singleSrc=cState.singleSrc;
  document.getElementById('solve-btn').disabled=true;
  setSolveMsg('Solving…');
  pyodide.globals.set('nW',nW);pyodide.globals.set('nC',nC);
  pyodide.globals.set('fixed',fixedCosts);pyodide.globals.set('cap',capacities);
  pyodide.globals.set('dem',demands);pyodide.globals.set('cost_js',matrix.flat());
  pyodide.globals.set('min_open',minOpen);pyodide.globals.set('max_open',maxOpen);
  pyodide.globals.set('min_util',minUtilPct/100);pyodide.globals.set('single_source',singleSrc);
  const code=`
import numpy as np,json
from scipy.optimize import milp,LinearConstraint,Bounds
cost=np.array(cost_js).reshape(nW,nC).tolist()
def yi(w):return w
def qi(w,c):return nW+w*nC+c
nVars=nW+nW*nC
c_obj=np.zeros(nVars)
for w in range(nW):
  c_obj[yi(w)]=fixed[w]
  [c_obj.__setitem__(qi(w,c),cost[w][c]) for c in range(nC)]
integrality=np.zeros(nVars)
for w in range(nW):integrality[yi(w)]=1
lb=np.zeros(nVars);ub=np.full(nVars,np.inf)
for w in range(nW):ub[yi(w)]=1.0
rows,lo_b,hi_b=[],[],[]
def add(r,lo,hi):rows.append(r);lo_b.append(lo);hi_b.append(hi)
for c in range(nC):
  r=np.zeros(nVars)
  for w in range(nW):r[qi(w,c)]=1.0
  add(r,dem[c],np.inf)
for w in range(nW):
  r=np.zeros(nVars)
  for c in range(nC):r[qi(w,c)]=1.0
  r[yi(w)]=-cap[w];add(r,-np.inf,0.0)
if min_util>0:
  for w in range(nW):
    r=np.zeros(nVars)
    for c in range(nC):r[qi(w,c)]=1.0
    r[yi(w)]=-min_util*cap[w];add(r,0.0,np.inf)
BIG_M=float(max(max(cap),sum(dem))+1)
for w in range(nW):
  for c in range(nC):
    r=np.zeros(nVars);r[qi(w,c)]=1.0;r[yi(w)]=-BIG_M;add(r,-np.inf,0.0)
r=np.zeros(nVars)
for w in range(nW):r[yi(w)]=1.0
add(r,float(min_open),float(max_open))
if single_source:
  for c in range(nC):
    r=np.zeros(nVars)
    for w in range(nW):r[qi(w,c)]=1.0
    add(r,dem[c],dem[c])
  for w in range(nW):
    for c in range(nC):ub[qi(w,c)]=dem[c]
lc=LinearConstraint(np.array(rows),lo_b,hi_b)
bd=Bounds(lb,ub)
res=milp(c_obj,constraints=lc,integrality=integrality,bounds=bd,options={"disp":False})
if res.status==0:
  x=res.x
  ow=[int(round(x[yi(w)])) for w in range(nW)]
  shp=[[round(max(x[qi(w,c)],0),2) for c in range(nC)] for w in range(nW)]
  fc=sum(fixed[w]*ow[w] for w in range(nW))
  tc=round(sum(cost[w][c]*shp[w][c] for w in range(nW) for c in range(nC)),2)
  out={"status":"Optimal","open":ow,"ships":shp,"fix":fc,"trans":tc,"total":round(fc+tc,2)}
else:
  msgs={1:"Iteration limit",2:"Infeasible — relax constraints",3:"Unbounded"}
  out={"status":msgs.get(res.status,f"Error {res.status}")}
json.dumps(out)`;
  try{
    const raw=await pyodide.runPythonAsync(code);
    const res=JSON.parse(raw);
    if(res.status!=='Optimal'){setSolveMsg(res.status,'err');document.getElementById('solve-btn').disabled=false;return}
    setSolveMsg(`Optimal · $${res.total.toLocaleString()}`,'ok');
    renderResults(res,nW,nC,fixedCosts,capacities,demands,matrix);
  }catch(e){setSolveMsg(e.message.slice(0,80),'err')}
  document.getElementById('solve-btn').disabled=false;
}

function resetView(){document.getElementById('results').classList.remove('show');document.getElementById('empty-state').style.display='flex'}

// ══════════════════════════════════════════════════════════════
// Q1 — RENDER
// ══════════════════════════════════════════════════════════════
function renderResults(res,nW,nC,fixedCosts,capacities,demands,matrix){
  document.getElementById('empty-state').style.display='none';
  document.getElementById('results').classList.add('show');
  animateCount('m-fix',res.fix,'$');animateCount('m-trans',res.trans,'$');animateCount('m-total',res.total,'$');
  let whHtml='';
  for(let w=0;w<nW;w++){
    const isOpen=res.open[w]===1,shipped=res.ships[w].reduce((a,b)=>a+b,0),util=isOpen?Math.round(shipped/capacities[w]*100):0;
    whHtml+=`<div class="wh-pill ${isOpen?'open':'closed'}"><div class="wh-led ${isOpen?'on':''}"></div><span>WH${w+1}</span>${isOpen?`<div class="util-track"><div class="util-fill" style="width:${util}%"></div></div><span class="wh-pct">${util}%</span>`:'<span class="wh-pct">closed</span>'}</div>`;
  }
  document.getElementById('wh-row').innerHTML=whHtml;
  const openIdx=res.open.map((o,i)=>o===1?i:-1).filter(i=>i>=0);
  let tbl='<table class="ship-table"><thead><tr><th class="lh">Warehouse</th>';
  for(let c=0;c<nC;c++) tbl+=`<th>C${c+1}<br><span style="color:var(--text3)">${demands[c]}u</span></th>`;
  tbl+='<th>Sent</th><th>Fixed</th></tr></thead><tbody>';
  for(const w of openIdx){
    const rt=res.ships[w].reduce((a,b)=>a+b,0);
    tbl+=`<tr><td class="lh">WH${w+1}</td>`;
    for(let c=0;c<nC;c++){const v=res.ships[w][c];tbl+=v>0?`<td class="pos">${v}<span class="sub">$${(matrix[w][c]*v).toFixed(0)}</span></td>`:`<td class="zero">—</td>`}
    tbl+=`<td class="pos">${rt.toFixed(1)}</td><td class="pos">$${fixedCosts[w]}</td></tr>`;
  }
  tbl+='<tr class="foot"><td>Received</td>';
  for(let c=0;c<nC;c++) tbl+=`<td>${res.ships.reduce((s,r)=>s+r[c],0).toFixed(1)}</td>`;
  tbl+='<td colspan="2"></td></tr></tbody></table>';
  document.getElementById('ship-wrap').innerHTML=tbl;
  renderConstraints(res,nW,nC,fixedCosts,capacities,demands,matrix);
  setTimeout(()=>drawNetwork(res,nW,nC,demands,matrix),50);
}
function animateCount(id,target,prefix=''){
  const el=document.getElementById(id),dur=600,steps=40;let i=0;
  const iv=setInterval(()=>{i++;el.textContent=prefix+Math.round(target*(i/steps)).toLocaleString();if(i>=steps)clearInterval(iv)},dur/steps);
}
function renderConstraints(res,nW,nC,fixedCosts,capacities,demands,matrix){
  const openWH=res.open.map((o,i)=>o===1?i:-1).filter(i=>i>=0);
  const minOpen=cState.minOpen?parseInt(document.getElementById('minOpenVal').value):null;
  const maxOpen=cState.maxOpen?parseInt(document.getElementById('maxOpenVal').value):null;
  const minUtil=cState.minUtil?parseFloat(document.getElementById('minUtilVal').value)/100:null;
  const nOpen=openWH.length;const items=[];
  let allDemandMet=true;
  const demD=demands.map((d,c)=>{const rv=res.ships.reduce((s,r)=>s+r[c],0);if(rv<d-0.01)allDemandMet=false;return`C${c+1}:${rv.toFixed(1)}≥${d}`});
  items.push({pass:allDemandMet,active:true,eq:'∑<sub>w</sub> q<sub>wc</sub> ≥ d<sub>c</sub>  ∀c',detail:demD.join(' · ')});
  let allCapOk=true;
  const capD=openWH.map(w=>{const s=res.ships[w].reduce((a,b)=>a+b,0);if(s>capacities[w]+0.01)allCapOk=false;return`WH${w+1}:${s.toFixed(1)}≤${capacities[w]}`});
  items.push({pass:allCapOk,active:true,eq:'∑<sub>c</sub> q<sub>wc</sub> ≤ CAP<sub>w</sub>·y<sub>w</sub>  ∀w',detail:capD.join(' · ')});
  let linkOk=true;
  for(let w=0;w<nW;w++)if(!res.open[w]&&res.ships[w].some(v=>v>0.01)){linkOk=false;break}
  items.push({pass:linkOk,active:true,eq:'q<sub>wc</sub> ≤ M·y<sub>w</sub>  ∀w,c',detail:linkOk?'All flows from open warehouses':'Flow from closed warehouse'});
  if(minOpen!==null){const ok=nOpen>=minOpen;items.push({pass:ok,active:true,eq:`∑<sub>w</sub> y<sub>w</sub> ≥ ${minOpen}`,detail:`${nOpen} open ≥ ${minOpen}`})}
  else items.push({pass:false,active:false,eq:'∑<sub>w</sub> y<sub>w</sub> ≥ K',detail:'Disabled'});
  if(minUtil!==null){
    let ok=true;
    const ud=openWH.map(w=>{const s=res.ships[w].reduce((a,b)=>a+b,0),mn=minUtil*capacities[w];if(s<mn-0.01)ok=false;return`WH${w+1}:${s.toFixed(1)}≥${mn.toFixed(1)}`});
    items.push({pass:ok,active:true,eq:`∑<sub>c</sub> q<sub>wc</sub> ≥ ${Math.round(minUtil*100)}%·CAP<sub>w</sub>·y<sub>w</sub>  ∀w`,detail:ud.join(' · ')});
  } else items.push({pass:false,active:false,eq:'∑<sub>c</sub> q<sub>wc</sub> ≥ α·CAP<sub>w</sub>·y<sub>w</sub>  ∀w',detail:'Disabled'});
  if(maxOpen!==null){const ok=nOpen<=maxOpen;items.push({pass:ok,active:true,eq:`∑<sub>w</sub> y<sub>w</sub> ≤ ${maxOpen}`,detail:`${nOpen} open ≤ ${maxOpen}`})}
  else items.push({pass:false,active:false,eq:'∑<sub>w</sub> y<sub>w</sub> ≤ K',detail:'Disabled'});
  if(cState.singleSrc){
    let ok=true;const sd=demands.map((d,c)=>{const src=res.ships.filter(r=>r[c]>0.01).length;if(src>1)ok=false;return`C${c+1}:${src}src`});
    items.push({pass:ok,active:true,eq:'∑<sub>w</sub> x<sub>wc</sub> = 1  ∀c',detail:sd.join(' · ')});
  } else items.push({pass:false,active:false,eq:'∑<sub>w</sub> x<sub>wc</sub> = 1  ∀c',detail:'Disabled'});
  document.getElementById('cverify-list').innerHTML=items.map(it=>{
    const cls=!it.active?'skip':it.pass?'pass':'fail',icon=!it.active?'○':it.pass?'✓':'✗',bc=cls,bt=!it.active?'OFF':it.pass?'SATISFIED':'VIOLATED';
    return`<div class="cv-row ${cls}"><div class="cv-icon" style="color:${!it.active?'var(--text3)':it.pass?'var(--glow2)':'var(--glow3)'}">${icon}</div><div class="cv-eq"><div class="eq-main">${it.eq}</div><div class="eq-val">${it.detail}</div></div><div class="cv-badge ${bc}">${bt}</div></div>`;
  }).join('');
}
function drawNetwork(res,nW,nC,demands,matrix){
  const canvas=document.getElementById('network-canvas'),parent=canvas.parentElement;
  canvas.width=parent.clientWidth-40;canvas.height=parent.clientHeight-52;
  const W=canvas.width,H=canvas.height,ctx=canvas.getContext('2d');
  const GLOW='#3b8bff',GLOW2='#00e5a0',TEXT2='#6b8aaa';
  ctx.clearRect(0,0,W,H);
  const openIdx=res.open.map((o,i)=>o===1?i:-1).filter(i=>i>=0);
  const closedIdx=res.open.map((o,i)=>o===0?i:-1).filter(i=>i>=0);
  const pad=40,whY=i=>pad+i*((H-pad*2)/Math.max(nW-1,1)),cY=i=>pad+i*((H-pad*2)/Math.max(nC-1,1)),whX=W*0.25,cX=W*0.75;
  const maxFlow=Math.max(...res.ships.flat().filter(v=>v>0),1);
  for(let w=0;w<nW;w++){if(!res.open[w])continue;for(let c=0;c<nC;c++){const v=res.ships[w][c];if(v<=0)continue;const t=v/maxFlow,alpha=0.2+t*0.6;ctx.beginPath();ctx.moveTo(whX,whY(w));ctx.bezierCurveTo(W*0.5,whY(w),W*0.5,cY(c),cX,cY(c));ctx.strokeStyle=`rgba(59,139,255,${alpha})`;ctx.lineWidth=0.5+t*3;ctx.stroke();ctx.fillStyle=`rgba(59,139,255,${alpha+0.2})`;ctx.font=`400 9px 'JetBrains Mono',monospace`;ctx.textAlign='center';ctx.textBaseline='middle';ctx.fillText(v.toFixed(0),W*0.5,(whY(w)+cY(c))/2-4)}}
  for(const w of closedIdx){ctx.beginPath();ctx.arc(whX,whY(w),10,0,Math.PI*2);ctx.fillStyle='#17202c';ctx.fill();ctx.strokeStyle='#2a2f42';ctx.lineWidth=1;ctx.stroke();ctx.fillStyle='#3a5070';ctx.font=`500 9px 'JetBrains Mono',monospace`;ctx.textAlign='center';ctx.textBaseline='middle';ctx.fillText(`W${w+1}`,whX,whY(w))}
  for(const w of openIdx){const x=whX,y=whY(w);const g=ctx.createRadialGradient(x,y,0,x,y,20);g.addColorStop(0,'rgba(59,139,255,0.25)');g.addColorStop(1,'rgba(59,139,255,0)');ctx.beginPath();ctx.arc(x,y,20,0,Math.PI*2);ctx.fillStyle=g;ctx.fill();ctx.beginPath();ctx.arc(x,y,12,0,Math.PI*2);ctx.fillStyle='#0c1118';ctx.fill();ctx.strokeStyle=GLOW;ctx.lineWidth=1.5;ctx.stroke();ctx.fillStyle=GLOW;ctx.font=`500 9px 'JetBrains Mono',monospace`;ctx.textAlign='center';ctx.textBaseline='middle';ctx.fillText(`W${w+1}`,x,y);ctx.fillStyle=TEXT2;ctx.font=`400 9px 'JetBrains Mono',monospace`;ctx.textAlign='right';ctx.textBaseline='middle';ctx.fillText(`${Math.round(res.ships[w].reduce((a,b)=>a+b,0))}u`,x-18,y)}
  for(let c=0;c<nC;c++){const x=cX,y=cY(c),recv=res.ships.reduce((s,r)=>s+r[c],0),met=Math.abs(recv-demands[c])<0.01;const g=ctx.createRadialGradient(x,y,0,x,y,20);g.addColorStop(0,met?'rgba(0,229,160,0.18)':'rgba(255,107,53,0.18)');g.addColorStop(1,'rgba(0,0,0,0)');ctx.beginPath();ctx.arc(x,y,20,0,Math.PI*2);ctx.fillStyle=g;ctx.fill();ctx.beginPath();ctx.arc(x,y,12,0,Math.PI*2);ctx.fillStyle='#0c1118';ctx.fill();ctx.strokeStyle=met?GLOW2:'#ff6b35';ctx.lineWidth=1.5;ctx.stroke();ctx.fillStyle=met?GLOW2:'#ff6b35';ctx.font=`500 9px 'JetBrains Mono',monospace`;ctx.textAlign='center';ctx.textBaseline='middle';ctx.fillText(`C${c+1}`,x,y);ctx.fillStyle=TEXT2;ctx.font=`400 9px 'JetBrains Mono',monospace`;ctx.textAlign='left';ctx.textBaseline='middle';ctx.fillText(`${demands[c]}u`,x+18,y)}
  ctx.font=`400 9px 'JetBrains Mono',monospace`;ctx.textAlign='left';ctx.textBaseline='middle';
  const leg=[[GLOW,'Open WH'],['#2a2f42','Closed WH'],[GLOW2,'Demand met']];let lx=10,ly=H-14;
  for(const[col,lbl]of leg){ctx.beginPath();ctx.arc(lx+4,ly,4,0,Math.PI*2);ctx.fillStyle=col;ctx.fill();ctx.fillStyle=TEXT2;ctx.fillText(lbl,lx+12,ly);lx+=ctx.measureText(lbl).width+28}
}

// ══════════════════════════════════════════════════════════════
// Q2(f) — FORECASTING (pure JS, no Python needed)
// ══════════════════════════════════════════════════════════════
function runQ2(){
  const raw=document.getElementById('q2-demands').value;
  const demand=raw.split(/[\n,]+/).map(s=>parseFloat(s.trim())).filter(v=>!isNaN(v));
  const n=demand.length;
  if(n<4){document.getElementById('q2-msg').textContent='Need at least 4 data points';document.getElementById('q2-msg').className='solve-msg-el err';return}
  const alphas=[
    parseFloat(document.getElementById('alpha1').value),
    parseFloat(document.getElementById('alpha2').value),
    parseFloat(document.getElementById('alpha3').value)
  ];
  const maN=parseInt(document.getElementById('ma-n').value);
  const maFrom=parseInt(document.getElementById('ma-from').value);

  // SES: F[1]=D[0], F[t]=alpha*D[t-1]+(1-alpha)*F[t-1]
  function computeSES(alpha){
    const F=[demand[0]];
    for(let t=1;t<n;t++) F.push(alpha*demand[t-1]+(1-alpha)*F[t-1]);
    // forecast for month n+1
    const Fnext=alpha*demand[n-1]+(1-alpha)*F[n-1];
    return{F,Fnext};
  }
  // MAPE over all periods starting from index 1 (month 2)
  function mape(actual,forecast,fromIdx=1){
    let s=0,cnt=0;
    for(let t=fromIdx;t<actual.length;t++){s+=Math.abs((actual[t]-forecast[t])/actual[t]);cnt++}
    return(s/cnt)*100;
  }

  const ses=alphas.map(a=>computeSES(a));
  const sesMAPE=ses.map(s=>mape(demand,s.F));

  // Moving Average: MA[t] = mean(D[t-n]..D[t-1]), valid from t=maN (0-indexed)
  // MAPE from period maFrom (1-indexed) → index maFrom-1
  const maF=new Array(n).fill(null);
  for(let t=maN;t<n;t++){
    let sum=0;for(let k=t-maN;k<t;k++)sum+=demand[k];
    maF[t]=sum/maN;
  }
  let maMAPEsum=0,maMAPEcnt=0;
  const maFromIdx=maFrom-1;
  for(let t=maFromIdx;t<n;t++){if(maF[t]!==null){maMAPEsum+=Math.abs((demand[t]-maF[t])/demand[t]);maMAPEcnt++}}
  const maMapePct=maMAPEcnt>0?(maMAPEsum/maMAPEcnt)*100:null;
  const maNxt=demand.slice(n-maN).reduce((a,b)=>a+b,0)/maN;

  // Best SES
  const bestIdx=sesMAPE.indexOf(Math.min(...sesMAPE));
  const bestAlpha=alphas[bestIdx];

  document.getElementById('q2-msg').textContent=`Done · Best α=${bestAlpha} (MAPE ${sesMAPE[bestIdx].toFixed(2)}%)`;
  document.getElementById('q2-msg').className='solve-msg-el ok';

  renderQ2(demand,n,alphas,ses,sesMAPE,maF,maMapePct,maNxt,maN,maFrom,bestIdx);
}

function renderQ2(demand,n,alphas,ses,sesMAPE,maF,maMapePct,maNxt,maN,maFrom,bestIdx){
  const out=document.getElementById('q2-output');
  const maLabel=`${maN}-Period MA`;

  // MAPE comparison cards
  let metricsHtml='<div class="q2-metrics">';
  alphas.forEach((a,i)=>{
    const best=i===bestIdx;
    metricsHtml+=`<div class="q2-metric${best?' best':''}">
      <div class="q2m-label">SES α = ${a}</div>
      <div class="q2m-val${best?' green':''}">MAPE ${sesMAPE[i].toFixed(2)}%</div>
      <div class="q2m-sub">Month ${n+1} forecast: <strong>${ses[i].Fnext.toFixed(2)}</strong></div>
    </div>`;
  });
  metricsHtml+=`<div class="q2-metric">
    <div class="q2m-label">${maLabel} (periods ${maFrom}–${n})</div>
    <div class="q2m-val">MAPE ${maMapePct!==null?maMapePct.toFixed(2)+'%':'—'}</div>
    <div class="q2m-sub">Month ${n+1} forecast: <strong>${maNxt.toFixed(2)}</strong></div>
  </div>`;
  metricsHtml+='</div>';

  // Full forecast table
  let tblHtml=`<div class="q2-full"><div class="q2-card-title">Forecast table — all months</div>
  <div style="overflow-x:auto"><table class="fc-table">
  <thead><tr>
    <th class="lh">Month</th><th>Actual D</th>
    ${alphas.map(a=>`<th>SES α=${a}</th>`).join('')}
    <th>${maLabel}</th>
  </tr></thead><tbody>`;
  for(let t=0;t<n;t++){
    const isMA=maF[t]!==null;
    tblHtml+=`<tr>
      <td class="lh">${t+1}</td>
      <td class="hi">${demand[t]}</td>
      ${ses.map((s,i)=>{const v=s.F[t],ape=t>0?Math.abs((demand[t]-v)/demand[t])*100:null;return`<td class="${i===bestIdx&&t>0?'best-cell':''}">${v.toFixed(2)}${t>0?`<span class="sub">${ape.toFixed(1)}%</span>`:''}</td>`}).join('')}
      <td class="${isMA&&t>=maFrom-1?'hi zero':''}">${isMA?maF[t].toFixed(2):'—'}${isMA&&t>=maFrom-1?`<span class="sub">${(Math.abs((demand[t]-maF[t])/demand[t])*100).toFixed(1)}%</span>`:''}</td>
    </tr>`;
  }
  // Month n+1 row
  tblHtml+=`<tr style="border-top:1px solid var(--border2)">
    <td class="lh">${n+1} (fcst)</td><td class="hi">—</td>
    ${ses.map((s,i)=>`<td class="${i===bestIdx?'best-cell':''}">${s.Fnext.toFixed(2)}</td>`).join('')}
    <td class="hi">${maNxt.toFixed(2)}</td>
  </tr>`;
  // MAPE row
  tblHtml+=`<tr class="sum-row">
    <td class="lh">MAPE</td><td>—</td>
    ${sesMAPE.map((m,i)=>`<td class="${i===bestIdx?'best-cell':''}">${m.toFixed(2)}%</td>`).join('')}
    <td>${maMapePct!==null?maMapePct.toFixed(2)+'%':'—'}</td>
  </tr>`;
  tblHtml+='</tbody></table></div></div>';

  // Verdict
  const bestSES=`SES with α = ${alphas[bestIdx]}`;
  const maVsSesBetter=maMapePct!==null&&maMapePct<sesMAPE[bestIdx];
  const overallBest=maVsSesBetter?`${maN}-Period MA (MAPE ${maMapePct.toFixed(2)}%)`:` ${bestSES} (MAPE ${sesMAPE[bestIdx].toFixed(2)}%)`;
  const verdictHtml=`<div class="verdict-box">
    <div class="vline">Model comparison — Q2(f) verdict</div>
    <strong>Equation used (SES):</strong> F<sub>t+1</sub> = α · D<sub>t</sub> + (1 − α) · F<sub>t</sub><br>
    <strong>Moving Average equation:</strong> MA<sub>t</sub> = (D<sub>t−1</sub> + D<sub>t−2</sub> + … + D<sub>t−n</sub>) / n<br>
    <strong>Best SES model:</strong> α = ${alphas[bestIdx]} — MAPE ${sesMAPE[bestIdx].toFixed(2)}%. ${alphas[bestIdx]>=0.7?'High α → responsive, tracks trend quickly but volatile.':alphas[bestIdx]<=0.3?'Low α → stable, smooth but slow to react to changes.':'Moderate α → balanced responsiveness and stability.'}<br>
    <strong>${maN}-Period MA MAPE (periods ${maFrom}–${n}):</strong> ${maMapePct!==null?maMapePct.toFixed(2)+'%':'N/A'}<br>
    <strong>Overall best model:</strong>${overallBest}<br>
    ${maVsSesBetter
      ?`Moving Average outperforms SES here, suggesting the demand series is relatively stable with low noise, making the simple average effective.`
      :`SES outperforms MA — its weighted recency bias handles the upward trend better than a simple average of past periods.`}
  </div>`;

  // Mini chart
  const chartHtml=`<div class="q2-full"><div class="q2-card-title">Demand vs forecasts</div><div class="q2-canvas-wrap"><canvas id="q2-chart"></canvas></div></div>`;

  out.innerHTML=metricsHtml+chartHtml+tblHtml+verdictHtml;

  // Draw chart
  setTimeout(()=>{
    const canvas=document.getElementById('q2-chart');
    if(!canvas)return;
    const par=canvas.parentElement;
    canvas.width=par.clientWidth;canvas.height=par.clientHeight;
    const W=canvas.width,H=canvas.height,ctx=canvas.getContext('2d');
    const pad={t:12,r:16,b:28,l:40};
    const cW=W-pad.l-pad.r,cH=H-pad.t-pad.b;
    const allVals=[...demand,...ses.flatMap(s=>s.F),...maF.filter(v=>v!==null)];
    const minV=Math.min(...allVals)*0.97,maxV=Math.max(...allVals)*1.01;
    const px=t=>pad.l+t*(cW/(n-1)),py=v=>pad.t+cH-(v-minV)/(maxV-minV)*cH;
    ctx.clearRect(0,0,W,H);
    // Grid
    ctx.strokeStyle='rgba(80,160,255,0.08)';ctx.lineWidth=1;
    for(let i=0;i<=4;i++){const y=pad.t+cH*i/4;ctx.beginPath();ctx.moveTo(pad.l,y);ctx.lineTo(W-pad.r,y);ctx.stroke()}
    // Actual demand
    ctx.beginPath();ctx.moveTo(px(0),py(demand[0]));
    for(let t=1;t<n;t++)ctx.lineTo(px(t),py(demand[t]));
    ctx.strokeStyle='#d8e8f8';ctx.lineWidth=1.5;ctx.stroke();
    // SES lines
    const cols=['#3b8bff','#ff6b35','#b44fff'];
    ses.forEach((s,i)=>{
      ctx.beginPath();ctx.moveTo(px(0),py(s.F[0]));
      for(let t=1;t<n;t++)ctx.lineTo(px(t),py(s.F[t]));
      ctx.strokeStyle=cols[i];ctx.lineWidth=1;ctx.setLineDash([]);ctx.stroke();
    });
    // MA line
    ctx.setLineDash([4,3]);ctx.strokeStyle='#00e5a0';ctx.lineWidth=1.5;ctx.beginPath();
    let started=false;
    for(let t=0;t<n;t++){if(maF[t]===null)continue;if(!started){ctx.moveTo(px(t),py(maF[t]));started=true}else ctx.lineTo(px(t),py(maF[t]))}
    ctx.stroke();ctx.setLineDash([]);
    // X labels
    ctx.fillStyle='#3a5070';ctx.font=`9px 'JetBrains Mono',monospace`;ctx.textAlign='center';ctx.textBaseline='top';
    for(let t=0;t<n;t+=3)ctx.fillText(t+1,px(t),H-pad.b+4);
    // Legend
    const legItems=[['#d8e8f8','Actual'],...alphas.map((a,i)=>[cols[i],`α=${a}`]),['#00e5a0',`${maN}-MA`]];
    let lx=pad.l;const ly=4;
    ctx.font=`9px 'JetBrains Mono',monospace`;ctx.textBaseline='top';
    for(const[col,lbl]of legItems){ctx.fillStyle=col;ctx.fillRect(lx,ly,12,2);ctx.fillStyle='#6b8aaa';ctx.textAlign='left';ctx.fillText(lbl,lx+16,ly-1);lx+=ctx.measureText(lbl).width+32}
  },60);
}

initPy();
</script>
