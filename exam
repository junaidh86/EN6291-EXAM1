<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>Supply Chain Solver — Q1 & Q2</title>
<link href="https://fonts.googleapis.com/css2?family=Syne:wght@400;500;600;700;800&family=JetBrains+Mono:wght@300;400;500&display=swap" rel="stylesheet">
<style>
:root {
  --bg0:#0d1220; --bg1:#121c2e; --bg2:#192438; --bg3:#1f2e44;
  --panel:rgba(13,18,32,0.97);
  --border:rgba(110,175,255,0.22); --border2:rgba(110,175,255,0.42);
  --glow:#6ab0ff; --glow2:#00f5b0; --glow3:#ff8550;
  --text:#f0f6ff; --text2:#a8c4e0; --text3:#6890b0;
  --mono:'JetBrains Mono',monospace; --display:'Syne',sans-serif;
}
*,*::before,*::after{box-sizing:border-box;margin:0;padding:0}
html,body{height:100%}
body{font-family:var(--display);background:var(--bg0);color:var(--text);overflow:hidden;height:100vh}
body::before{content:'';position:fixed;inset:0;background-image:linear-gradient(rgba(59,139,255,0.03) 1px,transparent 1px),linear-gradient(90deg,rgba(59,139,255,0.03) 1px,transparent 1px);background-size:40px 40px;pointer-events:none;z-index:0}
.blob{position:fixed;border-radius:50%;filter:blur(80px);pointer-events:none;z-index:0}
.blob1{width:500px;height:500px;background:rgba(59,139,255,0.06);top:-100px;left:-100px}
.blob2{width:400px;height:400px;background:rgba(0,229,160,0.05);bottom:-80px;right:300px}
.blob3{width:300px;height:300px;background:rgba(255,107,53,0.04);top:40%;right:-50px}

/* ── Layout ── */
.app{position:relative;z-index:1;display:grid;grid-template-rows:56px 1fr;height:100vh}
header{display:flex;align-items:center;gap:16px;padding:0 24px;border-bottom:1px solid var(--border2);background:var(--panel);backdrop-filter:blur(12px)}
.logo-mark{width:32px;height:32px;border:1.5px solid var(--glow);border-radius:6px;display:flex;align-items:center;justify-content:center;font-family:var(--mono);font-size:11px;font-weight:500;color:var(--glow);box-shadow:0 0 12px rgba(59,139,255,0.25),inset 0 0 8px rgba(59,139,255,0.08)}
.app-title{font-size:15px;font-weight:700;letter-spacing:0.12em;text-transform:uppercase;color:var(--text)}
.app-sub{font-family:var(--mono);font-size:12px;color:var(--text3);letter-spacing:0.06em}

/* ── Tabs in header ── */
.tab-bar{display:flex;align-items:stretch;gap:2px;margin-left:32px;height:100%}
.tab-btn{font-family:var(--mono);font-size:12px;letter-spacing:0.08em;text-transform:uppercase;padding:0 20px;background:none;border:none;border-bottom:2px solid transparent;color:var(--text3);cursor:pointer;transition:color 0.2s,border-color 0.2s;white-space:nowrap}
.tab-btn:hover{color:var(--text2)}
.tab-btn.active{color:var(--glow);border-bottom-color:var(--glow)}

.header-sep{flex:1}
#engine-status{display:flex;align-items:center;gap:8px;font-family:var(--mono);font-size:11px;color:var(--text2);padding:5px 12px;border:1px solid var(--border2);border-radius:100px;background:var(--bg2)}
.status-dot{width:6px;height:6px;border-radius:50%;background:var(--text3);transition:background 0.4s}
.status-dot.loading{background:var(--glow3);animation:pulse-dot 1s infinite}
.status-dot.ready{background:var(--glow2);box-shadow:0 0 6px var(--glow2)}
.status-dot.err{background:#ff4444}
@keyframes pulse-dot{0%,100%{opacity:1}50%{opacity:0.3}}

/* ── Tab pages ── */
.tab-page{display:none;grid-template-columns:360px 1fr;overflow:hidden;height:100%}
.tab-page.active{display:grid}

/* ── Shared sidebar ── */
.sidebar{background:var(--panel);backdrop-filter:blur(12px);border-right:1px solid var(--border2);display:flex;flex-direction:column;overflow:hidden}
.sidebar-scroll{flex:1;overflow-y:auto;padding:20px}
.sidebar-scroll::-webkit-scrollbar{width:4px}
.sidebar-scroll::-webkit-scrollbar-thumb{background:var(--border2);border-radius:2px}
.panel-label{font-family:var(--mono);font-size:11px;letter-spacing:0.18em;text-transform:uppercase;color:var(--text3);margin-bottom:12px;padding-bottom:8px;border-bottom:1px solid var(--border);display:flex;align-items:center;gap:8px}
.panel-label::before{content:'';display:inline-block;width:12px;height:1px;background:var(--glow);box-shadow:0 0 4px var(--glow)}
.s-section{margin-bottom:22px}
.field{margin-bottom:12px}
.field label{font-family:var(--mono);font-size:11px;letter-spacing:0.06em;text-transform:uppercase;color:var(--text2);display:block;margin-bottom:5px}
.field input[type=text],.field input[type=number],.field textarea{width:100%;background:var(--bg2);border:1px solid var(--border2);border-radius:6px;padding:9px 12px;color:var(--text);font-family:var(--mono);font-size:13px;outline:none;transition:border-color 0.2s,box-shadow 0.2s}
.field input:focus,.field textarea:focus{border-color:var(--glow);box-shadow:0 0 0 2px rgba(59,139,255,0.12)}
.field textarea{resize:vertical;line-height:1.9}
.dim-row{display:grid;grid-template-columns:1fr 1fr;gap:10px}
input[type=number]{-moz-appearance:textfield;appearance:textfield}

/* ── Constraint pills ── */
.constraint-list{display:flex;flex-direction:column;gap:8px}
.c-item{background:var(--bg2);border:1px solid var(--border);border-radius:8px;padding:10px 12px;transition:border-color 0.2s}
.c-item.active{border-color:rgba(59,139,255,0.3)}
.c-item.locked{opacity:0.6}
.c-head{display:flex;align-items:center;gap:10px}
.c-check{width:16px;height:16px;border-radius:4px;border:1.5px solid var(--border2);background:transparent;cursor:pointer;display:flex;align-items:center;justify-content:center;flex-shrink:0;transition:background 0.2s,border-color 0.2s;position:relative}
.c-check.checked{background:var(--glow);border-color:var(--glow);box-shadow:0 0 8px rgba(59,139,255,0.4)}
.c-check.checked::after{content:'';position:absolute;width:4px;height:7px;border-right:1.5px solid #fff;border-bottom:1.5px solid #fff;transform:rotate(45deg) translate(-1px,-1px)}
.c-check.locked-check{background:rgba(0,229,160,0.15);border-color:rgba(0,229,160,0.4);cursor:default}
.c-check.locked-check::after{content:'';position:absolute;width:4px;height:7px;border-right:1.5px solid var(--glow2);border-bottom:1.5px solid var(--glow2);transform:rotate(45deg) translate(-1px,-1px)}
.c-name{font-size:13px;font-weight:500;color:var(--text);flex:1}
.c-tag{font-family:var(--mono);font-size:11px;color:var(--glow2);background:rgba(0,229,160,0.08);border:1px solid rgba(0,229,160,0.2);border-radius:3px;padding:1px 5px}
.c-body{margin-top:10px;padding-top:8px;border-top:1px solid var(--border);display:none}
.c-body.open{display:flex;align-items:center;gap:8px}
.c-body input[type=number]{width:72px;background:var(--bg3);border:1px solid var(--border2);border-radius:5px;padding:6px 10px;color:var(--text);font-family:var(--mono);font-size:13px;outline:none;-moz-appearance:textfield;appearance:textfield}
.c-body span{font-family:var(--mono);font-size:12px;color:var(--text2)}

/* ── Solve footer ── */
.sidebar-footer{padding:16px 20px;border-top:1px solid var(--border)}
.solve-btn{width:100%;padding:14px;border:none;border-radius:8px;background:linear-gradient(135deg,#1a4aff 0%,#0a90ff 100%);color:#fff;font-family:var(--display);font-size:14px;font-weight:700;letter-spacing:0.1em;text-transform:uppercase;cursor:pointer;position:relative;overflow:hidden;transition:opacity 0.2s,transform 0.15s;box-shadow:0 0 24px rgba(26,74,255,0.35),0 2px 8px rgba(0,0,0,0.4)}
.solve-btn::before{content:'';position:absolute;top:0;left:-100%;width:100%;height:100%;background:linear-gradient(90deg,transparent,rgba(255,255,255,0.12),transparent);transition:left 0.5s}
.solve-btn:hover::before{left:100%}
.solve-btn:hover{opacity:0.9}
.solve-btn:active{transform:scale(0.98)}
.solve-btn:disabled{background:var(--bg3);box-shadow:none;color:var(--text3);cursor:not-allowed}
.solve-msg-el{font-family:var(--mono);font-size:12px;color:var(--text3);text-align:center;margin-top:8px;min-height:14px}
.solve-msg-el.err{color:#ff6060}
.solve-msg-el.ok{color:var(--glow2)}

/* ── Output panel ── */
.output{display:grid;grid-template-rows:auto 1fr;overflow:hidden;background:var(--bg0)}
.empty{height:100%;display:flex;flex-direction:column;align-items:center;justify-content:center;gap:16px;color:var(--text2);font-family:var(--mono);font-size:14px;text-align:center}
.empty-ring{width:80px;height:80px;border-radius:50%;border:1px solid var(--border2);display:flex;align-items:center;justify-content:center;position:relative}
.empty-ring::before{content:'';position:absolute;width:60px;height:60px;border-radius:50%;border:1px dashed var(--border);animation:spin 8s linear infinite}
@keyframes spin{to{transform:rotate(360deg)}}
.empty-ring-inner{font-size:28px;opacity:0.4}

/* ── Q1 results ── */
.results{display:none;grid-template-rows:auto 1fr;overflow:hidden}
.results.show{display:grid}
.metrics-bar{display:grid;grid-template-columns:repeat(3,1fr) auto;gap:1px;border-bottom:1px solid var(--border2);background:var(--border)}
.metric-tile{background:var(--bg1);padding:16px 24px;position:relative;overflow:hidden}
.metric-tile::after{content:'';position:absolute;bottom:0;left:0;right:0;height:2px;background:var(--glow);opacity:0;transition:opacity 0.4s}
.metric-tile.total::after{background:var(--glow2);opacity:1;box-shadow:0 0 8px var(--glow2)}
.mt-label{font-family:var(--mono);font-size:11px;letter-spacing:0.08em;text-transform:uppercase;color:var(--text2);margin-bottom:6px}
.mt-val{font-family:var(--mono);font-size:26px;font-weight:500;color:var(--text);letter-spacing:-0.02em}
.mt-val.accent{color:var(--glow2)}
.metric-tile.solve-again{display:flex;align-items:center;justify-content:center;padding:16px}
.solve-again-btn{font-family:var(--mono);font-size:12px;color:var(--text2);background:var(--bg2);border:1px solid var(--border2);border-radius:6px;padding:6px 14px;cursor:pointer;letter-spacing:0.06em;transition:border-color 0.2s,color 0.2s;white-space:nowrap}
.solve-again-btn:hover{border-color:var(--glow);color:var(--glow)}
.results-body{display:grid;grid-template-columns:1fr 1fr;overflow:hidden}
.graph-panel{border-right:1px solid var(--border);padding:20px;display:flex;flex-direction:column;gap:12px;overflow:hidden}
.panel-title{font-family:var(--mono);font-size:11px;letter-spacing:0.1em;text-transform:uppercase;color:var(--text3);display:flex;align-items:center;gap:8px}
.panel-title::before{content:'';display:inline-block;width:12px;height:1px;background:var(--glow);box-shadow:0 0 4px var(--glow)}
#network-canvas{flex:1;border-radius:8px;background:var(--bg2);border:1px solid var(--border)}
.table-panel{padding:20px;overflow-y:auto;display:flex;flex-direction:column;gap:16px}
.table-panel::-webkit-scrollbar{width:4px}
.table-panel::-webkit-scrollbar-thumb{background:var(--border2);border-radius:2px}
.wh-row{display:flex;gap:8px;flex-wrap:wrap}
.wh-pill{display:flex;align-items:center;gap:8px;padding:9px 14px;border-radius:6px;border:1px solid var(--border);background:var(--bg2);font-family:var(--mono);font-size:13px;transition:border-color 0.3s}
.wh-pill.open{border-color:rgba(59,139,255,0.35)}
.wh-pill.closed{opacity:0.5}
.wh-led{width:7px;height:7px;border-radius:50%;background:var(--text3)}
.wh-led.on{background:var(--glow2);box-shadow:0 0 6px var(--glow2)}
.wh-pct{font-size:12px;color:var(--text2)}
.util-track{width:50px;height:3px;background:var(--border);border-radius:2px;overflow:hidden}
.util-fill{height:100%;background:var(--glow);border-radius:2px;transition:width 0.8s cubic-bezier(0.34,1.56,0.64,1)}
.ship-wrap{overflow-x:auto}
.ship-table{width:100%;border-collapse:collapse;font-family:var(--mono);font-size:11px}
.ship-table th{background:var(--bg2);border:1px solid var(--border2);padding:8px 12px;text-align:center;font-weight:500;color:var(--text2);font-size:12px;letter-spacing:0.04em;text-transform:uppercase;white-space:nowrap}
.ship-table th.lh{text-align:left}
.ship-table td{border:1px solid var(--border);padding:8px 12px;text-align:center;color:var(--text2);font-size:13px}
.ship-table td.lh{text-align:left;color:var(--text);background:var(--bg2);white-space:nowrap;font-size:13px}
.ship-table td.pos{color:var(--text);font-weight:500}
.ship-table td.zero{color:var(--text3)}
.ship-table tr.foot td{background:var(--bg2);color:var(--text);border-top:1px solid var(--border2)}
.sub{display:block;font-size:11px;color:var(--text3);margin-top:2px}
.cverify-list{display:flex;flex-direction:column;gap:6px}
.cv-row{display:grid;grid-template-columns:16px 1fr auto;align-items:center;gap:10px;background:var(--bg2);border:1px solid var(--border);border-radius:6px;padding:8px 10px;transition:border-color 0.3s}
.cv-row.pass{border-color:rgba(0,229,160,0.25)}
.cv-row.fail{border-color:rgba(255,107,53,0.35)}
.cv-row.skip{opacity:0.45}
.cv-icon{font-size:12px;line-height:1;text-align:center}
.cv-eq{font-family:var(--mono);font-size:12px;color:var(--text2);line-height:1.6}
.cv-eq .eq-main{color:var(--text);font-size:13px}
.cv-eq .eq-val{color:var(--text2);font-size:11px;margin-top:2px}
.cv-badge{font-family:var(--mono);font-size:11px;padding:2px 8px;border-radius:3px;white-space:nowrap;letter-spacing:0.05em}
.cv-badge.pass{background:rgba(0,229,160,0.1);color:var(--glow2);border:1px solid rgba(0,229,160,0.2)}
.cv-badge.fail{background:rgba(255,107,53,0.1);color:var(--glow3);border:1px solid rgba(255,107,53,0.2)}
.cv-badge.skip{background:var(--bg3);color:var(--text3);border:1px solid var(--border)}

/* ── Q2 Forecasting tab ── */
.q2-output{padding:24px;overflow-y:auto;background:var(--bg0);height:100%}
.q2-output::-webkit-scrollbar{width:4px}
.q2-output::-webkit-scrollbar-thumb{background:var(--border2);border-radius:2px}
.q2-metrics{display:grid;grid-template-columns:repeat(4,1fr);gap:10px;margin-bottom:20px}
.q2-metric{background:var(--bg1);border:1px solid var(--border);border-radius:8px;padding:14px 16px}
.q2-metric.best{border-color:rgba(0,229,160,0.35)}
.q2-metric.best::after{content:'BEST';position:absolute;top:10px;right:10px;font-family:var(--mono);font-size:8px;color:var(--glow2);letter-spacing:0.1em}
.q2-metric{position:relative}
.q2m-label{font-family:var(--mono);font-size:11px;color:var(--text2);text-transform:uppercase;letter-spacing:0.06em;margin-bottom:6px}
.q2m-val{font-family:var(--mono);font-size:22px;font-weight:500;color:var(--text)}
.q2m-val.green{color:var(--glow2)}
.q2m-sub{font-family:var(--mono);font-size:12px;color:var(--text2);margin-top:4px}
.q2-grid{display:grid;grid-template-columns:1fr 1fr;gap:16px;margin-bottom:16px}
.q2-card{background:var(--bg1);border:1px solid var(--border);border-radius:8px;padding:16px}
.q2-card-title{font-family:var(--mono);font-size:11px;color:var(--text2);text-transform:uppercase;letter-spacing:0.08em;margin-bottom:12px;padding-bottom:8px;border-bottom:1px solid var(--border);display:flex;align-items:center;gap:8px}
.q2-card-title::before{content:'';display:inline-block;width:10px;height:1px;background:var(--glow);box-shadow:0 0 4px var(--glow)}
.q2-full{background:var(--bg1);border:1px solid var(--border);border-radius:8px;padding:16px;margin-bottom:16px}
.fc-table{width:100%;border-collapse:collapse;font-family:var(--mono);font-size:10px}
.fc-table th{background:var(--bg2);border:1px solid var(--border2);padding:7px 10px;text-align:center;color:var(--text2);font-weight:500;font-size:11px;letter-spacing:0.04em;text-transform:uppercase;white-space:nowrap}
.fc-table th.lh{text-align:left}
.fc-table td{border:1px solid var(--border);padding:6px 10px;text-align:center;color:var(--text2);font-size:12px}
.fc-table td.lh{text-align:left;color:var(--text);background:var(--bg2);font-size:12px}
.fc-table td.hi{color:var(--text);font-weight:500}
.fc-table tr.ma-row td{color:var(--glow3)}
.fc-table tr.ma-row td.lh{color:var(--glow3)}
.fc-table tr.sum-row td{background:var(--bg2);color:var(--text);border-top:1px solid var(--border2);font-weight:500}
.fc-table td.best-cell{color:var(--glow2);font-weight:500}
.q2-canvas-wrap{width:100%;height:180px;position:relative}
canvas.q2-chart{width:100%;height:100%;border-radius:6px;background:var(--bg2);border:1px solid var(--border)}
.verdict-box{background:var(--bg2);border:1px solid rgba(0,245,176,0.3);border-radius:8px;padding:16px 20px;font-family:var(--mono);font-size:13px;line-height:1.9;color:var(--text2)}
.verdict-box strong{color:var(--text);font-weight:500}
.verdict-box .vline{color:var(--text2);font-size:11px;margin-bottom:8px;text-transform:uppercase;letter-spacing:0.08em}

@keyframes slide-up{from{opacity:0;transform:translateY(16px)}to{opacity:1;transform:translateY(0)}}
</style>
</head>
<body>
<div class="blob blob1"></div>
<div class="blob blob2"></div>
<div class="blob blob3"></div>

<div class="app">
  <header>
    <div class="logo-mark">SC</div>
    <div>
      <div class="app-title">Supply Chain Solver</div>
      <div class="app-sub">ENGG·6291 · Exam Solutions</div>
    </div>
    <div class="tab-bar">
      <button class="tab-btn active" onclick="switchTab('q1',this)">Q1 — Facility Location</button>
      <button class="tab-btn" onclick="switchTab('q2',this)">Q2(f) — Forecasting</button>
    </div>
    <div class="header-sep"></div>
    <div id="engine-status">
      <div class="status-dot loading" id="sdot"></div>
      <span id="stext">Loading engine…</span>
    </div>
  </header>

  <!-- ══════════════════════════════════════════════ TAB: Q1 ══ -->
  <div class="tab-page active" id="tab-q1">
    <div class="sidebar">
      <div class="sidebar-scroll">
        <div class="s-section">
          <div class="panel-label">Dimensions</div>
          <div class="dim-row">
            <div class="field"><label>Warehouses (W)</label><input type="number" id="nW" value="4" min="1" max="10"></div>
            <div class="field"><label>Customers (C)</label><input type="number" id="nC" value="5" min="1" max="10"></div>
          </div>
        </div>
        <div class="s-section">
          <div class="panel-label">Parameters</div>
          <div class="field"><label>Fixed costs — W1, W2, … ($)</label><input type="text" id="fixedCosts" value="850, 700, 950, 600"></div>
          <div class="field"><label>Capacities — W1, W2, … (units)</label><input type="text" id="capacities" value="120, 100, 140, 90"></div>
          <div class="field"><label>Demands — C1, C2, … (units)</label><input type="text" id="demands" value="40, 55, 35, 45, 50"></div>
          <div class="field"><label>Cost matrix (row per warehouse)</label>
            <textarea id="costMatrix" rows="5">4, 6, 9, 5, 8
5, 4, 7, 6, 5
6, 5, 4, 3, 6
8, 7, 5, 4, 3</textarea>
          </div>
        </div>
        <div class="s-section">
          <div class="panel-label">Constraints</div>
          <div class="constraint-list">
            <div class="c-item locked"><div class="c-head"><div class="c-check locked-check"></div><span class="c-name">Satisfy all demand</span><span class="c-tag">CORE</span></div></div>
            <div class="c-item locked"><div class="c-head"><div class="c-check locked-check"></div><span class="c-name">Capacity limits</span><span class="c-tag">CORE</span></div></div>
            <div class="c-item locked"><div class="c-head"><div class="c-check locked-check"></div><span class="c-name">Ship from open warehouses only</span><span class="c-tag">CORE</span></div></div>
            <div class="c-item active" id="ci_minOpen"><div class="c-head" onclick="toggleConstraint('minOpen')"><div class="c-check checked" id="ck_minOpen"></div><span class="c-name">Min warehouses open</span></div><div class="c-body open" id="cb_minOpen"><span>At least</span><input type="number" id="minOpenVal" value="2" min="1" max="10"><span>warehouse(s)</span></div></div>
            <div class="c-item active" id="ci_minUtil"><div class="c-head" onclick="toggleConstraint('minUtil')"><div class="c-check checked" id="ck_minUtil"></div><span class="c-name">Min utilization if open</span></div><div class="c-body open" id="cb_minUtil"><span>At least</span><input type="number" id="minUtilVal" value="40" min="0" max="100"><span>% of capacity</span></div></div>
            <div class="c-item" id="ci_maxOpen"><div class="c-head" onclick="toggleConstraint('maxOpen')"><div class="c-check" id="ck_maxOpen"></div><span class="c-name">Max warehouses open</span></div><div class="c-body" id="cb_maxOpen"><span>At most</span><input type="number" id="maxOpenVal" value="3" min="1" max="10"><span>warehouse(s)</span></div></div>
            <div class="c-item" id="ci_singleSrc"><div class="c-head" onclick="toggleConstraint('singleSrc')"><div class="c-check" id="ck_singleSrc"></div><span class="c-name">Single-source assignment</span></div></div>
          </div>
